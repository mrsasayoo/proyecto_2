# ═══════════════════════════════════════════════════════════════
# Datasets (ignore content but keep directory structure via .gitkeep)
# ═══════════════════════════════════════════════════════════════
# Ignore ALL files in datasets subdirectories EXCEPT .gitkeep
datasets/nih_chest_xrays/*
!datasets/nih_chest_xrays/.gitkeep

datasets/isic_2019/*
!datasets/isic_2019/.gitkeep

datasets/osteoarthritis/*
!datasets/osteoarthritis/.gitkeep

datasets/luna_lung_cancer/*
